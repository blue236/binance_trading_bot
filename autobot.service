[Unit]
Description=Crypto AutoBot (Binance Spot) - Headless (no GUI)
After=network.target

[Service]
Type=simple
User=%i
WorkingDirectory=/opt/binance_spot_gui_bot
ExecStart=/opt/binance_spot_gui_bot/.venv/bin/python /opt/binance_spot_gui_bot/main.py
Restart=on-failure
RestartSec=10
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
